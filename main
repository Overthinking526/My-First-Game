def lost():
    global game_exit
    global player_hp
    global emeny_hit
    global player_x, player_y
    global dead_player

    if (player_hp <= 0):
        print("Проиграл лох педальный :)))))) Рестарт игры: ")
        player_hp = 20
        game_map[player_x][player_y] = dead_player
        player_x = 1
        player_y = 1
    elif (player_gold == 6):
        print("Ты победил: ")
        game_exit = 25

def main():
    global player_x, player_y
    global player_gold
    global player_hp
    global emeny_hit

    game_exit = 0

    while(True):

        game_exit += 1
        if (game_exit == 25):
            time_data = input("Хош выйти из игры? y|n: ")
            if (time_data == "y"):
                break
            elif (time_data == "n"):
                print("лан похуй едем дальше")
            else:
                break

        def move_player():
            player_move_time_data = input("Твой мув сучка: ")
            if (player_move_time_data == "d"):
                move_right()
            elif (player_move_time_data == "a"):
                move_left()
            elif (player_move_time_data == "s"):
                move_down()
            elif (player_move_time_data == "w"):
                move_up()

        lost()
        map_player()
        move_player()
        print("Деньги: " + str(player_gold), "Хп: " + str(player_hp))

if __name__ == "__main__":
    main()
